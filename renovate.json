{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommitType(chore)"
  ],
  "enabledManagers": ["npm", "github-actions", "dockerfile", "mise", "custom.regex"],
  "commitMessagePrefix": "chore(all): ",
  "commitMessageAction": "update",
  "commitBody": "Signed-off-by: Renovate Bot <bot@renovateapp.com>",
  "labels": ["dependencies"],
  "prConcurrentLimit": 50,
  "prHourlyLimit": 0,
  "platformAutomerge": true,
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "ignoreTests": false,
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "npm": {
    "minimumReleaseAge": "3 days"
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Makefile tool versions via inline renovate comments",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)( versioning=(?<versioning>[^\\s]+))?\\n[A-Z_]+\\s*:=\\s*(?<currentValue>[^\\s]+)"
      ]
    },
    {
      "customType": "regex",
      "description": "Track localgod/catalyst HEAD commit pinned in CATALYST_REF",
      "managerFilePatterns": ["/^CATALYST_REF$/"],
      "matchStrings": [
        "^(?<currentDigest>[a-f0-9]{40})"
      ],
      "currentValueTemplate": "main",
      "depNameTemplate": "localgod/catalyst",
      "packageNameTemplate": "https://github.com/localgod/catalyst",
      "datasourceTemplate": "git-refs"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true,
    "minimumReleaseAge": "0 days"
  },
  "packageRules": [
    {
      "description": "Wait 3 days before automerging major updates",
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Group GitHub Actions into one PR",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Group Docker ecosystem actions together",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["/^docker\\//"],
      "groupName": "docker/* actions"
    },
    {
      "description": "Group aquasecurity ecosystem (Trivy action + CLI tool pin)",
      "matchPackageNames": [
        "aquasecurity/trivy-action",
        "aquasecurity/trivy"
      ],
      "groupName": "aquasecurity"
    },
    {
      "description": "Group devDependencies non-major updates",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "dev-dependencies",
      "automerge": true
    },
    {
      "description": "Group type definitions",
      "matchPackageNames": ["/^@types\\//"],
      "groupName": "type-definitions",
      "automerge": true
    },
    {
      "description": "Catalyst upstream pin — open PR but never automerge (breaking-change risk)",
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["CATALYST_REF"],
      "matchDepNames": ["localgod/catalyst"],
      "automerge": false,
      "minimumReleaseAge": "1 day",
      "labels": ["dependencies", "catalyst-upstream"]
    }
  ]
}
